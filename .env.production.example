# Production server — points at the production Supabase project.
# Fill in real values in .env.production (gitignored). Copy this file:
#   cp .env.production.example .env.production

# Database — Supabase PostgreSQL connection string pieces (production project)
DB_HOST=db.<your-project-ref>.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=<supabase-db-password>

# JWT
JWT_SECRET=<supabase-jwt-secret>
JWT_EXPIRES_IN=3600

# App
PORT=8080
NODE_ENV=production

# CORS — production admin dashboard origin(s), comma-separated
CORS_ORIGIN=https://admin.airtac.app
