              "mode": "raw",
              "raw": "{\n  \"winningTeamId\": \"{{teamAlphaId}}\"\n}"
            }
          }
        },
        {
          "name": "7.3 End Match \u2014 Draw",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/matches/{{matchId}}/end",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"winningTeamId\": null\n}"
            }
          }
        }
