{
  "info": {
    "name": "AirsoftTac API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Full app flow: Auth \u2192 Field \u2192 Game Mode \u2192 Match \u2192 In-Game"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "accessToken",
      "value": ""
    },
    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "fieldId",
      "value": ""
    },
    {
      "key": "gameModeId",
      "value": ""
    },
    {
      "key": "matchId",
      "value": ""
    },
    {
      "key": "teamAlphaId",
      "value": ""
    },
    {
      "key": "teamBravoId",
      "value": ""
    },
    {
      "key": "eventId",
      "value": ""
    },
    {
      "key": "adminToken",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "0. Admin",
      "item": [
        {
          "name": "A.0 Bootstrap First Admin (ch\u1ec9 d\u00f9ng 1 l\u1ea7n)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/admin/auth/bootstrap",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\",\n  \"displayName\": \"Super Admin\"\n}"
            }
          }
        },
        {
          "name": "A.1 Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set(\"adminToken\", res.data.accessToken);",
                  "  console.log(\"Admin token saved\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/admin/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"Admin@123\"\n}"
            }
          }
        },
        {
          "name": "A.0 Create Admin Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/admin/auth/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin2\",\n  \"password\": \"SecurePass@456\",\n  \"displayName\": \"Field Manager\"\n}"
            }
          }
        },
        {
          "name": "A.2 Create Field",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) pm.collectionVariables.set(\"fieldId\", res.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/admin/fields",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jungle Zone Alpha\",\n  \"location\": \"Thu Duc, HCMC\",\n  \"lat\": 10.8231,\n  \"lng\": 106.6297,\n  \"description\": \"Dense jungle terrain\"\n}"
            }
          }
        },
        {
          "name": "A.3 Create Game Mode",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) pm.collectionVariables.set(\"gameModeId\", res.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/admin/fields/{{fieldId}}/game-modes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Team Deathmatch\",\n  \"description\": \"Last team standing wins\",\n  \"rules\": [\"Call HIT when shot\", \"No blind firing\"],\n  \"maxPlayers\": 20,\n  \"teamCount\": 2,\n  \"respawnEnabled\": true,\n  \"respawnDelaySeconds\": 30\n}"
            }
          }
        },
        {
          "name": "A.4 List Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/admin/users?page=0&size=20",
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "A.5 Promote User to Organizer",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/admin/users/<USER_ID>/role",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"organizer\"\n}"
            }
          }
        },
        {
          "name": "A.6 System Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/admin/stats"
          }
        },
        {
          "name": "A.7 Update Field",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/admin/fields/{{fieldId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jungle Zone Alpha V2\",\n  \"location\": \"Thu Duc, HCMC\"\n}"
            }
          }
        },
        {
          "name": "A.8 Delete Field (soft)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/admin/fields/{{fieldId}}"
          }
        }
      ]
    },
    {
      "name": "0. Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/health"
          }
        }
      ]
    },
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "1.1 Google Sign-In",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "  console.log('Token saved:', res.data.accessToken.substring(0, 30) + '...');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/auth/google",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idToken\": \"<GOOGLE_ID_TOKEN_FROM_ANDROID>\"\n}"
            }
          }
        },
        {
          "name": "1.2 Apple Sign-In",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/auth/apple",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identityToken\": \"<APPLE_IDENTITY_TOKEN_FROM_IOS>\",\n  \"displayName\": \"Chris Nguyen\",\n  \"email\": \"chris@example.com\"\n}"
            }
          }
        },
        {
          "name": "1.3 Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/v1/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "1.4 Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "2. User Profile",
      "item": [
        {
          "name": "2.1 Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/users/me"
          }
        },
        {
          "name": "2.2 Update Profile",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/users/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"displayName\": \"Chris Pro\"\n}"
            }
          }
        },
        {
          "name": "2.3 Register Device Token (FCM)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/users/me/device-token",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"fcm_token_here\",\n  \"platform\": \"android\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "3. Fields",
      "item": [
        {
          "name": "3.1 List Fields",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/fields?page=0&size=20",
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "3.2 Get Field Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/fields/{{fieldId}}"
          }
        },
        {
          "name": "3.3 Get Seed Field (hardcoded)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.content && res.content.length > 0) {",
                  "  pm.collectionVariables.set('fieldId', res.content[0].id);",
                  "  console.log('fieldId saved:', res.content[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/game-modes"
          }
        }
      ]
    },
    {
      "name": "4. Game Modes",
      "item": [
        {
          "name": "4.1 List All Game Modes",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res && res.length > 0) {",
                  "  pm.collectionVariables.set('gameModeId', res[0].id);",
                  "  console.log('gameModeId saved:', res[0].id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/game-modes"
          }
        },
        {
          "name": "4.2 Get Game Mode by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/game-modes/{{gameModeId}}"
          }
        }
      ]
    },
    {
      "name": "5. Events",
      "item": [
        {
          "name": "5.1 List Events",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/v1/events?page=0&size=20",
              "query": [
                {
                  "key": "page",
                  "value": "0"
                },
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            }
          }
        },
        {
          "name": "5.2 Create Event (organizer only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) pm.collectionVariables.set('eventId', res.data.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/events",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Weekend Skirmish\",\n  \"description\": \"Open event for all skill levels. Bring your own gear.\",\n  \"fieldId\": \"{{fieldId}}\",\n  \"startTime\": \"2026-07-01T08:00:00Z\",\n  \"endTime\": \"2026-07-01T17:00:00Z\",\n  \"maxCapacity\": 40\n}"
            }
          }
        },
        {
          "name": "5.3 Get Event Detail",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/events/{{eventId}}"
          }
        },
        {
          "name": "5.4 RSVP to Event",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/events/{{eventId}}/rsvp"
          }
        },
        {
          "name": "5.5 Cancel RSVP",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/events/{{eventId}}/rsvp"
          }
        }
      ]
    },
    {
      "name": "6. Match \u2014 Lobby",
      "item": [
        {
          "name": "6.1 Create Match (organizer only)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('matchId', res.data.id);",
                  "  console.log('matchId saved:', res.data.id);",
                  "  if (res.data.teams && res.data.teams.length >= 2) {",
                  "    pm.collectionVariables.set('teamAlphaId', res.data.teams[0].id);",
                  "    pm.collectionVariables.set('teamBravoId', res.data.teams[1].id);",
                  "    console.log('Alpha:', res.data.teams[0].id);",
                  "    console.log('Bravo:', res.data.teams[1].id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/matches",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fieldId\": \"{{fieldId}}\",\n  \"gameModeId\": \"{{gameModeId}}\"\n}"
            }
          }
        },
        {
          "name": "6.2 Get Match / Lobby State",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/matches/{{matchId}}"
          }
        },
        {
          "name": "6.3 Check Active Match (on app launch)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/matches/active"
          }
        },
        {
          "name": "6.4 Join Team Alpha",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/matches/{{matchId}}/join",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teamId\": \"{{teamAlphaId}}\"\n}"
            }
          }
        },
        {
          "name": "6.5 Join Team Bravo",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/matches/{{matchId}}/join",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"teamId\": \"{{teamBravoId}}\"\n}"
            }
          }
        },
        {
          "name": "6.6 Leave Team",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/matches/{{matchId}}/leave"
          }
        },
        {
          "name": "6.7 Start Match (organizer only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": "{{baseUrl}}/v1/matches/{{matchId}}/start"
          }
        }
      ]
    },
