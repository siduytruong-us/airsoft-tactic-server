# Database — cùng PostgreSQL với Spring Boot server
DB_HOST=localhost
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=

# JWT — cùng secret với Spring Boot (token cũ vẫn valid sau migration)
JWT_SECRET=your_supabase_jwt_secret_here
JWT_EXPIRES_IN=3600

# App
PORT=8080
NODE_ENV=development

# CORS (admin dashboard)
CORS_ORIGIN=http://localhost:3000
