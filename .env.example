# Staging server — budget setup: points at the SAME Supabase project as production.
# Fill in real values in .env.staging (gitignored). Copy this file:
#   cp .env.staging.example .env.staging

# Database — Supabase PostgreSQL via IPv4 transaction pooler (production project)
# Get from: Supabase Dashboard > Connect > ORM (Connection string)
DB_HOST=aws-1-us-east-1.pooler.supabase.com
DB_PORT=6543
DB_NAME=postgres
DB_USER=postgres.<your-project-ref>
DB_PASSWORD=<supabase-db-password>
DB_SSL=true

# JWT — same secret as production (tokens issued by staging must also be valid against prod DB)
JWT_SECRET=<supabase-jwt-secret>
JWT_EXPIRES_IN=3600

# App
PORT=8080
NODE_ENV=staging

# CORS — staging admin dashboard origin(s), comma-separated
CORS_ORIGIN=

# Supabase Storage — server-side cover image upload proxy (field/map covers)
# SUPABASE_URL: project URL (same Supabase project as production — budget setup)
# SUPABASE_SERVICE_ROLE_KEY: service_role secret key (NEVER expose to client / commit)
# Set via: flyctl secrets set -c fly.staging.toml SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<supabase-service-role-key>
